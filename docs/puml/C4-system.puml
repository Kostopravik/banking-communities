@startuml system
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title Система "Банковские сообщества и кэшбэк" - Уровень контекста (C4)

Person(user, "Клиент банка", "Пользователь мобильного приложения VTB")

System(sys, "Платформа сообществ", "Позволяет клиентам вступать в сообщества,\nсоздавать посты, получать персональный кэшбэк\nи рекомендации на основе транзакций")

System_Ext(ext, "Платёжная система", "Источник данных о транзакциях клиентов,\nисполняет начисление кэшбэка")

' Двустороннее взаимодействие пользователь ↔ система
Rel(user, sys, "Вступает в сообщества, пишет посты,\nпроверяет кэшбэк", "HTTPS (REST)")
Rel(sys, user, "Показывает ленту, сообщества,\nкэшбэк, рекомендации", "HTTPS (REST)")

' Двустороннее взаимодействие с платёжной системой
Rel(ext, sys, "Передаёт данные о транзакциях\n(MCC-коды, суммы, места)", "Async/DB import")
Rel(sys, ext, "Передаёт данные о начисленном кэшбэке\nдля зачисления на счета клиентов", "API/пакеты")

@enduml