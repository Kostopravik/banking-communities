@startuml containers
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title Платформа сообществ - Уровень контейнеров (C4)

Person(user, "Клиент банка")

System_Boundary(platform, "VTB Platform") {
    Container(flutter, "Flutter-приложение", "Dart", "Мобильное приложение для взаимодействия\nс сообществами и акциями")

    Container(api, "Backend API", "Python, FastAPI", "Обрабатывает бизнес-логику:\nавторизацию, посты, комментарии,\nкэшбэк и рекомендации")

    ContainerDb(pg, "Реляционная БД", "PostgreSQL", "Хранит данные пользователей, сообществ,\nпостов и кэшбэка")

    ContainerDb(neo, "Графовая БД", "Neo4j", "Хранит граф транзакций и интересов клиентов\n(User)-[HAS_TRANSACTION]->(Place)\n(Place)-[BELONGS_TO]->(Category)")
}

System_Ext(payment, "Платёжная система", "Процессинг транзакций,\nисточник MCC-кодов и сумм")

' Пользовательские потоки (двусторонние)
Rel(flutter, user, "Отображает данные пользователю", "")
Rel(user, flutter, "Использует", "")
Rel(flutter, api, "Передает данные запросов на получение постов / клиентов / кешбеков / сообществ", "")
Rel(api, flutter, "Передает данные постов / клиентов / кешбеков / сообществ", "")

Rel(pg, payment, "Передает данные о кебшеке пользователя", "")

' API ↔ PostgreSQL: чтение и запись
Rel(pg, api, "Передает данные о пользователе", "")
Rel(api, pg, "Передает данные\n(посты, лайки, комментарии)", "")

' API ↔ Neo4j: только чтение
Rel(neo, api, "Передает данные о транзакциях", "")

' Загрузка данных из платёжной системы (односторонние)
Rel(payment, pg, "Загрузка справочников:\nклиенты, сообщества, кэшбэк", "")
Rel(payment, neo, "Загрузка транзакций:\nклиент → место → сумма → MCC", "")

@enduml